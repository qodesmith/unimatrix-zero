{
  // Repo tooling (tools/**) — runs under Bun, not Electron's Node, so it gets
  // Bun's globals/types instead of the node config's. Everything else is
  // inherited from tsconfig.node.json.
  "extends": "./tsconfig.node.json",
  "include": ["tools/**/*"],
  "compilerOptions": {
    "types": ["bun"]
  }
}
