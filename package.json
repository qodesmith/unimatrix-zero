{
  "name": "app",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://electron-vite.org",
  "author": "Qodesmith",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "oxfmt -c .oxfmtrc.jsonc",
    "format:check": "oxfmt -c .oxfmtrc.jsonc --check",
    "lint": "oxlint -c .oxlintrc.jsonc",
    "test": "bun --bun vitest run",
    "lint:rule-changes": "bun --bun run ./tools/oxlint/get-rule-changes.ts",
    "lint:tailwind": "bun tools/tailwind/canonicalize-classes.ts",
    "lint:tailwind:apply": "bun tools/tailwind/canonicalize-classes.ts --apply",
    "lint:tailwind:regressions": "bun tools/tailwind/check-regressions.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web && bun run typecheck:tools",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "install-electron && electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@shadcn/react": "^0.2.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "oxc-parser": "^0.140.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
