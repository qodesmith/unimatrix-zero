{
  "name": "app",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "homepage": "https://electron-vite.org",
  "author": "Qodesmith",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "oxfmt -c .oxfmtrc.jsonc",
    "format:check": "oxfmt -c .oxfmtrc.jsonc --check",
    "lint": "oxlint -c .oxlintrc.jsonc",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "install-electron && electron-builder install-app-deps",
    "build:unpack": "bun run build && electron-builder --dir",
    "build:win": "bun run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@shadcn/react": "^0.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.70.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.12.1",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.1-rc",
    "vite": "^7.2.6"
  }
}
